# Dependencies
node_modules/
.pnp
.pnp.js

# Vendored agent skills — regenerable from skills-lock.json (like node_modules).
# .claude/skills/ holds symlinks into .agents/; ignore both, keep launch.json.
.agents/
.claude/skills/

# Environment & secrets — never commit
.env
.env.*
!.env.example

# Build output
build/
dist/
.react-router/
.cache/
coverage/

# Fly / deploy
.fly/

# Local tenant Corpus repos (runtime data; lives on a Fly volume in prod)
.data/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Temp
*.tmp
*~
